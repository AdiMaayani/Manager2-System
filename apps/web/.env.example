# API base URL.
# Development default: leave unset to use the Vite dev proxy (/api -> http://localhost:5162).
# Production: set this to the deployed API base path or origin, for example /api or https://api.example.com/api.
# VITE_API_BASE_URL=/api

# Data mode:
# - local: real API via apiRequest (default, production-safe)
# - mock: in-memory mock data for local UI work only; production builds fail when mock is selected
VITE_APP_DATA_MODE=local
